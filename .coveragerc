[run]
source = backend
omit =
    */tests/*
    */backend/thinking_tree/*
    */backend/system_team/*
    */backend/main.py
    */backend/checkpoint/*
    */backend/rag/rag_store.py

[report]
fail_under = 70
skip_empty = true
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    if TYPE_CHECKING:
