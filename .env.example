# ── 熔断器 ────────────────────────────────────────────────────────────────────
# LLM API 连续失败 N 次后熔断，拒绝所有后续调用，等待 reset_timeout 秒后进入半开状态
LLM_CB_MAXFAIL=5  # type: integer
LLM_CB_RESET=60  # type: float (seconds)

# ── Redis Sentinel 高可用 (可选) ───────────────────────────────────────────────
# 启用后使用 Redis Sentinel 自动故障转移，替代单机 redis:6379
# REDIS_SENTINEL_ENABLED=1
# REDIS_SENTINEL_HOSTS=sentinel-1:26379,sentinel-2:26379,sentinel-3:26379
# REDIS_SENTINEL_SERVICE=agent-studio-redis
# REDIS_SENTINEL_DB=0
# REDIS_PASSWORD=
# ── 数据库 ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/virtual_team  # type: string

# ── LLM API ─────────────────────────────────────────────────────────────────
# DeepSeek — primary provider（支持 reasoning_content 思维链输出）
DEEPSEEK_API_KEY=sk-your-deepseek-key  # type: string
OPENAI_API_KEY=sk-your-openai-key  # type: string
OPENAI_BASE_URL=https://api.deepseek.com  # type: string
OPENAI_MODEL=deepseek-v4-flash  # type: string
BAIDU_QIANFAN_API_KEY=  # type: string
EMBEDDING_MODEL=text-embedding-3-small  # type: string

# ── Celery / Redis ──────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0  # type: string
CELERY_RESULT_BACKEND=redis://localhost:6379/0  # type: string
REDIS_URL=redis://localhost:6379/1  # type: string

# ── 连接池 ──────────────────────────────────────────────────────────────────
DATABASE_POOL_SIZE=20      # type: int | DB 连接池大小（0 = NullPool，禁用池化）
DATABASE_POOL_OVERFLOW=10  # type: int | 池满后额外连接上限
REDIS_POOL_SIZE=20         # type: int | 每事件循环 Redis 连接上限（Celery prefork: 每进程独立池）

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173  # type: string | SECURITY: In production, set to your frontend domain (e.g. https://studio.example.com). Never use wildcard (*) with credentials.

# ── 限流 ────────────────────────────────────────────────────────────────────
RATE_LIMIT=120  # type: integer
RATE_LIMIT_WINDOW=60  # type: integer
# RATE_LIMIT_USER=200  # type: integer | per-user rate (optional; if unset, per-user limit is disabled)
# ── 安全 ────────────────────────────────────────────────────────────────────
# 请求体大小限制（默认 10MB，单位 bytes）
# MAX_REQUEST_BODY_SIZE=10485760  # type: integer
# 安全头覆盖（设为空字符串可禁用该头）
# X_CONTENT_TYPE_OPTIONS=nosniff  # type: string
# X_FRAME_OPTIONS=DENY  # type: string
# STRICT_TRANSPORT_SECURITY=max-age=31536000; includeSubDomains  # type: string

# ── 认证 ────────────────────────────────────────────────────────────────────
# legacy:  固定 admin 账号（admin / admin123），不用登录直接进入
# rbac:    需要登录注册，JWT 鉴权
AUTH_ENABLED=1  # type: boolean | SECURITY: Disable only for local dev without auth requirements
AUTH_SECRET=  # REQUIRED: Set a random secret >= 32 chars. CI will fail if not set.  # type: string | SECURITY: Rotate periodically. Never reuse across environments. Use `openssl rand -base64 48` to generate.
AUTH_MODE=legacy  # type: string (legacy|rbac) | SECURITY: Set to 'rbac' in production for real authentication.

# ── Key Vault ───────────────────────────────────────────────────────────────
KEY_VAULT_SECRET=  # REQUIRED: Set a random key >= 32 chars. CI will fail if not set.  # type: string | SECURITY: Store encrypted user API keys. Rotate if compromised. Use `python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'` to generate.
KEY_VAULT_SECRET_ROTATED=  # type: string
DATABASE_POOL_SIZE=20  # type: integer
DATABASE_POOL_OVERFLOW=10  # type: integer

# ── Checkpointer ────────────────────────────────────────────────────────────
CHECKPOINTER_BACKEND=sqlite  # type: string (memory|sqlite|postgres)
CHECKPOINTER_DSN=./.checkpoints.db  # type: string

# ── 邮件服务（邮箱验证 / 密码重置）───────────────────────────────────────────
# log:   仅打印日志（开发用，验证码在后端 stdout 可见）
# smtp:  通过 SMTP 真实发送，下面两种方案二选一
EMAIL_BACKEND=log  # type: string (log|smtp|resend)

# ── SMTP 方案：SendGrid（默认，通用企业级） ──────────────────────────────────
# 注册：https://sendgrid.com → Settings → API Keys → Create API Key
# 日发 100 封免费，专业送达率，无需备案域名
# EMAIL_BACKEND=smtp
# EMAIL_SMTP_HOST=smtp.sendgrid.net
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_TLS=1
# EMAIL_SMTP_USER=apikey
# EMAIL_SMTP_PASSWORD=SG.xxxxxxxxxxxxx
# EMAIL_FROM=your-verified-sender@example.com

# ── SMTP 方案（备用）：阿里云邮件推送（有备案域名后使用） ────────────────────
# 开通：阿里云控制台 → 邮件推送 → 验证域名 → 创建发信地址 → 获取 SMTP 密码
# EMAIL_BACKEND=smtp
# EMAIL_SMTP_HOST=smtpdm.aliyun.com
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_TLS=0
# EMAIL_SMTP_USER=noreply@yourcompany.com
# EMAIL_SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM=noreply@yourcompany.com

# ── 第三方工具 ──────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key  # type: string

# ── GC ─────────────────────────────────────────────────────────────────────
GC_INTERVAL=3600  # type: integer (seconds)

# ── 错误追踪 ─────────────────────────────────────────────────────────────────
SENTRY_DSN=  # type: string
SENTRY_ENVIRONMENT=development  # type: string (development|staging|production)
SENTRY_TRACES_SAMPLE_RATE=0.1  # type: float (0.0-1.0)
SENTRY_PROFILES_SAMPLE_RATE=0.1  # type: float (0.0-1.0)

# ── 可观测性 ─────────────────────────────────────────────────────────────────
OBSERVABILITY_ENABLED=1  # type: boolean
# 磁盘可用空间低于此值（MB）时停止写入事件，默认 100
OBSERVABILITY_MIN_DISK_MB=100  # type: integer

# ── 运行 ────────────────────────────────────────────────────────────────────
PORT=8080  # type: integer
LOG_LEVEL=INFO  # type: string (DEBUG|INFO|WARNING|ERROR)
LOG_FORMAT=%(asctime)s %(levelname)-8s [%(name)s] %(message)s  # type: string
UPLOAD_DIR=./uploads  # type: string
ENABLE_MOCK_FALLBACK=0  # type: boolean

# ── 邮件（仅用于 .env.example 覆盖检测，实际取值见上方章节）────────────────────
EMAIL_SMTP_HOST=placeholder  # type: string
EMAIL_SMTP_PORT=587  # type: integer
EMAIL_SMTP_TLS=1  # type: boolean
EMAIL_SMTP_USER=placeholder  # type: string
EMAIL_SMTP_PASSWORD=placeholder  # type: string
EMAIL_FROM=placeholder@example.com  # type: string
RESEND_API_KEY=placeholder  # type: string

# ── CSP (Content-Security-Policy) ─────────────────────────────────────────────
# 后端 API 响应 CSP 策略，默认 self-only。生产环境按需添加前端 origin
CSP_POLICY=default-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'  # type: string
# 前端开发服务器严格 CSP（可选，开启后 XSS 防护更强但可能影响热重载）
# VITE_ENABLE_STRICT_CSP=true

# ── 前端 ──────────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=  # type: string
