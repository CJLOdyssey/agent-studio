# ── 数据库 ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/virtual_team

# ── LLM API ─────────────────────────────────────────────────────────────────
# DeepSeek — primary provider（支持 reasoning_content 思维链输出）
DEEPSEEK_API_KEY=sk-your-deepseek-key
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
BAIDU_QIANFAN_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── Celery / Redis ──────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── 限流 ────────────────────────────────────────────────────────────────────
RATE_LIMIT=120
RATE_LIMIT_WINDOW=60

# ── 认证 ────────────────────────────────────────────────────────────────────
# legacy:  固定 admin 账号（admin / admin123），不用登录直接进入
# rbac:    需要登录注册，JWT 鉴权
AUTH_ENABLED=1
AUTH_SECRET=change-me-to-a-random-secret
AUTH_MODE=legacy

# ── Key Vault ───────────────────────────────────────────────────────────────
KEY_VAULT_SECRET=change-me-to-a-32-byte-key-for-fernet
KEY_VAULT_SECRET_ROTATED=
DATABASE_POOL_SIZE=20
DATABASE_POOL_OVERFLOW=10

# ── Checkpointer ────────────────────────────────────────────────────────────
CHECKPOINTER_BACKEND=sqlite
CHECKPOINTER_DSN=./.checkpoints.db

# ── 邮件服务（邮箱验证 / 密码重置）───────────────────────────────────────────
# log:   仅打印日志（开发用，验证码在后端 stdout 可见）
# smtp:  通过 SMTP 真实发送，下面两种方案二选一
EMAIL_BACKEND=log

# ── SMTP 方案：SendGrid（默认，通用企业级） ──────────────────────────────────
# 注册：https://sendgrid.com → Settings → API Keys → Create API Key
# 日发 100 封免费，专业送达率，无需备案域名
# EMAIL_BACKEND=smtp
# EMAIL_SMTP_HOST=smtp.sendgrid.net
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_TLS=1
# EMAIL_SMTP_USER=apikey
# EMAIL_SMTP_PASSWORD=SG.xxxxxxxxxxxxx
# EMAIL_FROM=your-verified-sender@example.com

# ── SMTP 方案（备用）：阿里云邮件推送（有备案域名后使用） ────────────────────
# 开通：阿里云控制台 → 邮件推送 → 验证域名 → 创建发信地址 → 获取 SMTP 密码
# EMAIL_BACKEND=smtp
# EMAIL_SMTP_HOST=smtpdm.aliyun.com
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_TLS=0
# EMAIL_SMTP_USER=noreply@yourcompany.com
# EMAIL_SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM=noreply@yourcompany.com

# ── 第三方工具 ──────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key

# ── GC ─────────────────────────────────────────────────────────────────────
GC_INTERVAL=3600

# ── 可观测性 ─────────────────────────────────────────────────────────────────
OBSERVABILITY_ENABLED=1
# 磁盘可用空间低于此值（MB）时停止写入事件，默认 100
OBSERVABILITY_MIN_DISK_MB=100

# ── 运行 ────────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s %(levelname)-8s [%(name)s] %(message)s
UPLOAD_DIR=./uploads
ENABLE_MOCK_FALLBACK=0

# ── 邮件（仅用于 .env.example 覆盖检测，实际取值见上方章节）────────────────────
EMAIL_SMTP_HOST=placeholder
EMAIL_SMTP_PORT=587
EMAIL_SMTP_TLS=1
EMAIL_SMTP_USER=placeholder
EMAIL_SMTP_PASSWORD=placeholder
EMAIL_FROM=placeholder@example.com
RESEND_API_KEY=placeholder
