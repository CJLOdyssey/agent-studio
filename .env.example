# ── 熔断器 ────────────────────────────────────────────────────────────────────
# LLM API 连续失败 N 次后熔断，拒绝所有后续调用，等待 reset_timeout 秒后进入半开状态
LLM_CB_MAXFAIL=5  # type: integer
LLM_CB_RESET=60  # type: float (seconds)

# ── Redis Sentinel 高可用 (可选) ───────────────────────────────────────────────
# 启用后使用 Redis Sentinel 自动故障转移，替代单机 redis:6379
# REDIS_SENTINEL_ENABLED=1
# REDIS_SENTINEL_HOSTS=sentinel-1:26379,sentinel-2:26379,sentinel-3:26379
# REDIS_SENTINEL_SERVICE=virtual-team-redis
# REDIS_SENTINEL_DB=0
# REDIS_PASSWORD=
