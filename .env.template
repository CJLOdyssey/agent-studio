# ═══════════════════════════════════════════════════════════════════════════
# API 配置（二选一）
# ═══════════════════════════════════════════════════════════════════════════
# 方式一：DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# 方式二：OpenAI
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ═══════════════════════════════════════════════════════════════════════════
# RAG 嵌入模型（DashScope，用于向量搜索）
# ═══════════════════════════════════════════════════════════════════════════
DASHSCOPE_API_KEY=your-dashscope-api-key
EMBEDDING_MODEL=text-embedding-v3

# ═══════════════════════════════════════════════════════════════════════════
# 安全配置
# ═══════════════════════════════════════════════════════════════════════════
# 密钥保险库加密密钥（必填，用于加密存储用户的 API Key）
# 生成方式: python3 -c "import secrets; print(secrets.token_hex(32))"
KEY_VAULT_SECRET=generate-me-with-secrets-token-hex-32

# ═══════════════════════════════════════════════════════════════════════════
# 团队配置
# ═══════════════════════════════════════════════════════════════════════════
MAX_ROUNDS=5
TEMPERATURE=0.7
TIMEOUT=120
MAX_RETRIES=3

# 日志配置
# LOG_LEVEL=DEBUG      # 取消注释开启调试日志
# LOG_FORMAT=json       # 取消注释使用 JSON 结构化日志（默认纯文本）

# 前端端口（默认 80，避免冲突可改为 3000）
PORT=80

# 安全限制
MAX_REQUIREMENT_LENGTH=2000

# ═══════════════════════════════════════════════════════════════════════════
# CORS 跨域配置（Docker/生产环境用）
# ═══════════════════════════════════════════════════════════════════════════
# 设置前端实际访问的域名，多个用逗号分隔
# 开发模式下默认已包含 localhost:5173 / localhost:8080，无需重复配置
# CORS_ORIGIN=https://your-production-domain.com
